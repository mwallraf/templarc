# ─────────────────────────────────────────────────────────────────────────────
# Templarc — Production environment template
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: .env must never be committed to version control.
# Generate a secure SECRET_KEY with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────


# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Credentials used by both the 'db' Docker service and the API container.
# The docker-compose.yml overrides DATABASE_URL to use the 'db' service
# hostname automatically — these vars are what Postgres itself uses.

POSTGRES_USER=templarc
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=templarc


# ─── API — Database connection ────────────────────────────────────────────────
# Used when running the API directly on the host (outside Docker).
# When running via docker compose, this is overridden to use the 'db' service
# hostname automatically — you do not need to change this for Docker usage.
#
# Accepted URL formats (all equivalent at runtime):
#   postgresql://user:pass@host/db            ← bare form (also works for psql)
#   postgresql+asyncpg://user:pass@host/db    ← asyncpg dialect (SQLAlchemy)
#
DATABASE_URL=postgresql://templarc:change-me-use-a-strong-password@localhost/templarc


# ─── Security ─────────────────────────────────────────────────────────────────
# REQUIRED. Used to sign and verify JWT access tokens.
# Generate with: openssl rand -hex 32

SECRET_KEY=replace-this-with-output-of-openssl-rand-hex-32


# ─── Template storage ─────────────────────────────────────────────────────────
# Path to the Git repository that holds .j2 template files.
# In Docker this is bind-mounted via docker-compose.yml (./templates_repo:/app/templates_repo).
# For host-only runs, set to the absolute or relative path on your machine.

TEMPLATES_REPO_PATH=./templates_repo


# ─── LDAP authentication ──────────────────────────────────────────────────────
# Leave LDAP_SERVER empty to disable LDAP and fall back to local bcrypt auth.
# When set, POST /auth/login delegates to the LDAP server; local passwords are
# ignored (use POST /auth/login/local only to manage local-only admin accounts).
#
# LDAP_SERVER     — ldap:// or ldaps:// URL of your directory server
# LDAP_BASE_DN    — DN under which user accounts live
#                   Users bind as:  uid=<username>,<LDAP_BASE_DN>
# LDAP_ADMIN_GROUP — Full DN of the group whose members receive is_admin=True.
#                    Leave empty to make all LDAP users non-admin.

LDAP_SERVER=ldap://your-ldap-server.example.com
LDAP_BASE_DN=ou=users,dc=company,dc=com
LDAP_ADMIN_GROUP=cn=admins,ou=groups,dc=company,dc=com


# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of origins the browser is allowed to call the API from.
# For a same-origin deployment (API behind nginx with /api prefix) use [].
# For a cross-origin deployment add your frontend origin here.

CORS_ORIGINS=["https://app.example.com"]


# ─── Datasource security ──────────────────────────────────────────────────────
# When false (recommended for production), the datasource resolver blocks
# requests to RFC-1918 private addresses to prevent SSRF attacks.
# Set to true only when the API legitimately needs to reach internal services.

ALLOW_PRIVATE_DATASOURCE_URLS=false


# ─── Seed data ────────────────────────────────────────────────────────────────
# When true, the API creates a demo organisation, project, and templates on
# first startup. Idempotent — skipped silently on subsequent starts.
# Set to false for production to avoid shipping demo data.

SEED_ON_STARTUP=false


# ─── Host port binding ────────────────────────────────────────────────────────
# FRONTEND_PORT — nginx serves the compiled React app and proxies /api/* to
#   the FastAPI container. This is the only port that needs to be publicly
#   reachable. For HTTPS, put a TLS-terminating reverse proxy in front.
# API_PORT — the FastAPI port. Not exposed to the host in production (the
#   frontend nginx container reaches it internally). Useful for staging/debug.

FRONTEND_PORT=80
API_PORT=8000
