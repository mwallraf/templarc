# ─────────────────────────────────────────────────────────────────────────────
# Templarc — Local development template
#
# Use this when running the API directly on your host machine while the
# supporting services (PostgreSQL, OpenLDAP) run in Docker via the dev stack:
#
#   make dev-d                          # start DB + LDAP in background
#   cp .env.local.example .env          # configure local API
#   uv run uvicorn api.main:app --reload  # run API on host
#
# For the fully-Dockerised dev experience (API also in Docker) just run:
#   make dev                            # everything in Docker, nothing to copy
#
# SECURITY: This file contains dev-only credentials. Never use these values
# in any environment accessible from the public internet.
# ─────────────────────────────────────────────────────────────────────────────


# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Credentials for the Docker Postgres container started by 'make dev-d'.
# The API reads these; Postgres reads them from docker-compose.yml directly.

POSTGRES_USER=templarc
POSTGRES_PASSWORD=templarcpwd
POSTGRES_DB=templarc


# ─── API — Database connection ────────────────────────────────────────────────
# Points to localhost because the DB is Docker-exposed on port 5432.

DATABASE_URL=postgresql://templarc:templarcpwd@localhost/templarc


# ─── Security ─────────────────────────────────────────────────────────────────
# Fixed dev-only secret key — do NOT reuse this in staging or production.

SECRET_KEY=dev-secret-key-do-not-use-in-production


# ─── Template storage ─────────────────────────────────────────────────────────

TEMPLATES_REPO_PATH=./templates_repo


# ─── LDAP authentication ──────────────────────────────────────────────────────
# Points to the OpenLDAP container started by 'make dev-d' (exposed on :389).
#
# Default test account: username=admin  password=admin
# All users in the 'users' group (the default group) receive is_admin=True.

LDAP_SERVER=ldap://localhost:389
LDAP_BASE_DN=ou=users,dc=templarc,dc=dev
LDAP_ADMIN_GROUP=cn=users,ou=groups,dc=templarc,dc=dev


# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allow the Vite dev server and common local ports.

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]


# ─── Datasource security ──────────────────────────────────────────────────────
# Enabled in dev so datasources can reach local/internal services for testing.

ALLOW_PRIVATE_DATASOURCE_URLS=true


# ─── Seed data ────────────────────────────────────────────────────────────────
# Auto-populate demo data on first startup (idempotent).

SEED_ON_STARTUP=true


# ─── AI assistant ─────────────────────────────────────────────────────────────
# Leave AI_PROVIDER empty to disable. Set to "anthropic" or "openai" to enable.

AI_PROVIDER=
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_BASE_URL=https://api.openai.com/v1


# ─── HTTP proxy (optional) ────────────────────────────────────────────────────
# Forwarded as Docker build-args during image build (apt-get, pip, npm ci).
# Leave empty if no proxy is needed.

HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1


# ─── Host port binding ────────────────────────────────────────────────────────
# In dev, the frontend Vite server runs on 5173 (Docker or npm run dev).
# The API is exposed on 8000 for direct Swagger / curl access.
# DB_PORT / LDAP_PORT / MOCK_API_PORT — change if the defaults conflict with
# other services already running on your machine.

FRONTEND_PORT=5173
API_PORT=8000
DB_PORT=5432
LDAP_PORT=389
MOCK_API_PORT=8088
