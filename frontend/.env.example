# Copy this file to .env.local and adjust as needed.
# Vite injects only variables prefixed with VITE_ into the browser bundle.

# API base URL.
#
# DEV (npm run dev):
#   Leave empty — the Vite dev proxy handles /api → http://localhost:8000.
#   The proxy target can be changed in vite.config.ts.
#
# PRODUCTION (same-origin deployment):
#   Leave empty — the browser will hit <same-origin>/api/...
#   Requires a reverse proxy (nginx, Caddy, etc.) to route /api → FastAPI.
#
# PRODUCTION (cross-origin deployment):
#   Set this to the full FastAPI origin, no trailing slash.
#   Example: VITE_API_URL=https://api.example.com
#
VITE_API_URL=
