{#-
  CPE Device: OneAccess LBB400
  ──────────────────────────────
  Sets ns.d with LBB400 device-specific config.
  ONEOS — high-end CPE with dual WAN, 4x LAN GigE + 1x WAN GigE + SFP.
  Supports advanced routing, NAT, and QoS. BVI-based LAN (no VLAN trunk).
-#}
{%- set ns.d = {
    'vendor':              'ONEACCESS',
    'os':                  'ONEOS',
    'model':               'LBB400',
    'wan_interface':       'GigabitEthernet 1/0',
    'lan_vlan_interface':  'Bvi',
    'loopback_interface':  'Loopback ',
    'ppp_interface':       'virtual-template ppp ',
    'tunnel_interface':    'Tunnel ',
    'supports_vlans':      False,
    'supports_sfp':        True,
    'dual_wan':            True,
    'qos_on_subint':       False,
    'nat_capable':         True,
    'mgmt_vlan':           None,
    'qos_policy_out':      'WAN-QOS-PREMIUM',
} -%}
